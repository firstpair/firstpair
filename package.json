{
  "name": "firstpair-site",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5182",
    "build": "vue-tsc -b && vite build",
    "prod:build": "vue-tsc -b && vite build --outDir dist-prod",
    "preview": "vite preview --host 127.0.0.1 --port 5183 --strictPort --outDir dist-prod",
    "check:catalog": "node scripts/check-public-catalog.mjs",
    "library:publish": "node scripts/publish-book-to-library.mjs",
    "books:upload": "node scripts/upload-book-package.mjs",
    "readers:sync": "node scripts/sync-reader-routes.mjs",
    "smoke:site": "node scripts/smoke-site.mjs",
    "test:book-build": "publishing/tests/test-build-library-book.sh",
    "test:vault-guide": "node publishing/tests/test-vault-guide-workflow.mjs"
  },
  "dependencies": {
    "@lucide/vue": "^1.17.0",
    "@vercel/blob": "^2.6.1",
    "vue": "3.5.38"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "11.15.0",
    "@playwright/test": "^1.60.0",
    "@tsconfig/node24": "^24.0.3",
    "@types/node": "^24.12.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vue-tsc": "^3.2.8"
  }
}
