{
  "framework": "vite",
  "buildCommand": "npm run prod:build",
  "outputDirectory": "dist-prod",
  "routes": [
    {
      "src": "^/read(?:/(.*))?$",
      "dest": "/api/reader?path=$1"
    },
    {
      "src": "^/learn(?:/(.*))?$",
      "dest": "/api/reader?path=$1&area=tutorial"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^/(.*)$",
      "dest": "/index.html"
    }
  ]
}
